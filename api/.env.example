# 复制本文件为 .env 后填写真实值（不要提交 .env 到 Git）
# 微信小程序（与公众平台「开发设置」一致；AppID 须与小程序前端 manifest「mp-weixin.appid」相同）
WX_MP_APPID=
WX_MP_SECRET=

# 可选别名（与 WechatService 读取逻辑一致，二选一即可）
# WECHAT_MINI_APPID=
# WECHAT_MINI_SECRET=

# 监听端口（宝塔 Node 项目若已设 PORT，可省略）
# PORT=8000

# MySQL（与宝塔「数据库」里实际账号一致；默认与 app.module 开发默认值相同）
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=baimaoadmin
# DB_PASSWORD=你的数据库密码
# DB_DATABASE=baimao_admin
